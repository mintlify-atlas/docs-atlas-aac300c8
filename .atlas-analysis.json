  "keyFeatures": [
    "Monitor PostgreSQL connection counts (total, active, idle, stale)",
    "Multi-tier threshold alerts (attention/alert/danger levels)",
    "Slack and Loki notification integration",
    "Kubernetes native support with kubectl port-forward",
    "Flexible deployment modes (one-shot, daemon, cron)",
    "Connection leak detection via stale connection monitoring",
    "Environment variable and CLI flag configuration"
  ],
  "publicApiSurface": [
    "pgwd -db-url <url> -threshold-total <n>",
    "pgwd -db-url <url> -threshold-levels <percentages>",
    "pgwd -db-url <url> -threshold-active <n>",
    "pgwd -db-url <url> -threshold-idle <n>",
    "pgwd -db-url <url> -stale-age <seconds> -threshold-stale <n>",
    "pgwd -kube-postgres <namespace>/<type>/<name>",
    "pgwd -slack-webhook <url>",
    "pgwd -loki-url <url> -loki-labels <labels>",
    "pgwd -interval <seconds>",
    "pgwd -dry-run",
    "pgwd -force-notification",
    "pgwd --version"
  ]
}
